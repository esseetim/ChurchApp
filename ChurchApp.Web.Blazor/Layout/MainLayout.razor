@inherits LayoutComponentBase

<RadzenComponents />
<RadzenDialog />
<RadzenNotification />

<div class="app-container">
    <header class="app-header">
        <div class="header-content">
            <p class="text-sm font-semibold tracking-wide text-blue-700">ChurchApp</p>
            <h1 class="mt-1 text-2xl font-bold text-slate-900">Volunteer Donations Desk</h1>
            <p class="mt-2 text-sm text-slate-600">Simple workflow for recording donations and generating summaries.</p>
        </div>
    </header>

    <nav class="app-nav">
        <NavLink href="/desk" class="nav-link" ActiveClass="nav-link-active" Match="NavLinkMatch.All">
            Donation Desk
        </NavLink>
        <NavLink href="/ledger" class="nav-link" ActiveClass="nav-link-active">
            Ledger
        </NavLink>
        <NavLink href="/summaries" class="nav-link" ActiveClass="nav-link-active">
            Summaries
        </NavLink>
        <NavLink href="/reports" class="nav-link" ActiveClass="nav-link-active">
            Reports
        </NavLink>
    </nav>

    <main class="app-main">
        @Body
    </main>
</div>

