@inherits LayoutComponentBase

<RadzenComponents />
<RadzenDialog />
<RadzenNotification />

<RadzenLayout class="app-shell">
    <RadzenHeader class="app-header">
        <div class="app-header-content">
            <div>
                <div class="app-title">ChurchApp</div>
                <div class="app-subtitle">Volunteer Donations Desk</div>
            </div>
            <RadzenIcon Icon="account_circle" class="profile-icon" />
        </div>
    </RadzenHeader>

    <RadzenSidebar>
        <RadzenPanelMenu ShowArrow="false">
            <RadzenPanelMenuItem Text="Directory" Icon="contacts" Path="/directory" />
            <RadzenPanelMenuItem Text="Donation Desk" Icon="point_of_sale" Path="/desk" />
            <RadzenPanelMenuItem Text="Ledger" Icon="receipt_long" Path="/ledger" />
            <RadzenPanelMenuItem Text="Summaries" Icon="analytics" Path="/summaries" />
            <RadzenPanelMenuItem Text="Reports" Icon="insights" Path="/reports" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody class="app-body">
        @Body
    </RadzenBody>
</RadzenLayout>
