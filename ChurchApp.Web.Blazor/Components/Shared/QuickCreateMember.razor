<RadzenCard Style="margin-bottom: 1rem;">
    <h3 class="text-sm font-semibold text-slate-900" style="margin-bottom: 0.75rem;">Quick Create Member</h3>
    
    <EditForm Model="@model" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.75rem;">
            <div>
                <RadzenTextBox @bind-Value="@model.FirstName" 
                              Placeholder="First name" 
                              Style="width: 100%;"
                              Disabled="@IsSubmitting" />
                <ValidationMessage For="@(() => model.FirstName)" />
            </div>
            <div>
                <RadzenTextBox @bind-Value="@model.LastName" 
                              Placeholder="Last name" 
                              Style="width: 100%;"
                              Disabled="@IsSubmitting" />
                <ValidationMessage For="@(() => model.LastName)" />
            </div>
        </div>
        
        <RadzenButton ButtonType="ButtonType.Submit" 
                     ButtonStyle="ButtonStyle.Primary" 
                     Text="Create Member"
                     Disabled="@IsSubmitting"
                     Icon="@(IsSubmitting ? "autorenew" : "person_add")"
                     IsBusy="@IsSubmitting" />
    </EditForm>
</RadzenCard>
